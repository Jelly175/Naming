# MySQL connection string used by Prisma.
# Keep this server-side only. Never prefix it with NEXT_PUBLIC_.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"

# MySQL connection pool settings.
# Start small for serverless deployments and increase only after observing traffic.
DB_POOL_CONNECTION_LIMIT="10"
DB_POOL_ACQUIRE_TIMEOUT_MS="10000"
DB_CONNECT_TIMEOUT_MS="10000"
DB_IDLE_TIMEOUT_MS="60000"

# Use true in production if your managed MySQL provider supports/requires TLS.
DB_SSL="false"

# Razorpay keys. Keep the secret key server-side only.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# WhatsApp provider credentials, for example Interakt, WATI, AiSensy, or Meta Cloud API.
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
WHATSAPP_BUSINESS_PHONE=""

# Public values can be read in the browser.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
